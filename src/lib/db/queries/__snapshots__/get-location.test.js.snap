// Jest Snapshot v1, https://goo.gl/fbAQLP

exports[`returns the expected query for valid parameters 1`] = `
"WITH
TARGET_LOCATION AS (
  SELECT
  LOCATION.LOCATION_ID,
  LOCATION.FEATURE_PK,
  FEATURE_NAME

  FROM
  AHBRP.LOCATION LOCATION,
  AHBRP.FEATURE FEATURE

  WHERE
  LOCATION.LOCATION_ID = 'L97339'
  AND
  LOCATION.FEATURE_PK = FEATURE.FEATURE_PK
),
TARGET_PRIMARY_ASSET_LOCATION AS (
  SELECT
  AL.FEATURE_PK,
  AL.ASSET_PK

  FROM
  TARGET_LOCATION LOCATION,
  AHBRP.ASSET_LOCATION AL

  WHERE
  LOCATION.FEATURE_PK = AL.FEATURE_PK
  AND
  AL.ASSET_LOCATION_TO_DATE IS NULL
  AND
  AL.ASSET_LOCATION_TYPE = 'PRIMARYLOCATION'
),
TARGET_LIVESTOCK_ASSET AS (
  SELECT DISTINCT
  AL.ASSET_PK

  FROM
  TARGET_PRIMARY_ASSET_LOCATION AL,
  AHBRP.LIVESTOCK_UNIT LU

  WHERE
  AL.ASSET_PK = LU.ASSET_PK
),
TARGET_FACILITY_ASSET AS (
  SELECT DISTINCT
  AL.ASSET_PK

  FROM
  TARGET_PRIMARY_ASSET_LOCATION AL,
  AHBRP.FACILITY FACILITY

  WHERE
  AL.ASSET_PK = FACILITY.ASSET_PK
),
LU_SPECIES AS (
  SELECT
  ASSET.ASSET_PK,
  RDCD.SHORT_DESCRIPTION

  FROM
  TARGET_LIVESTOCK_ASSET TLA,
  AHBRP.ASSET,
  AHBRP.ANIMAL,
  AHBRP.ANIMAL_SPECIES,
  AHBRP.REF_DATA_SET RDF,
  AHBRP.REF_DATA_CODE RDC,
  AHBRP.REF_DATA_CODE_DESC RDCD

  WHERE
  TLA.ASSET_PK = ASSET.ASSET_PK
  AND
  ASSET.ANIMAL_PK = ANIMAL.ANIMAL_PK
  AND
  ANIMAL.ANIMAL_SPECIES_PK = ANIMAL_SPECIES.ANIMAL_SPECIES_PK
  AND
  ANIMAL_SPECIES_TO_DATE IS NULL
  AND
  RDC.REF_DATA_SET_PK = RDF.REF_DATA_SET_PK
  AND
  RDF.REF_DATA_SET_NAME = 'ANIMAL_SPECIES'
  AND
  ANIMAL_SPECIES.ANIMAL_SPECIES_CODE = RDC.CODE
  AND
  RDC.EFFECTIVE_TO_DATE = '31-DEC-9999'
  AND
  RDC.REF_DATA_CODE_PK = RDCD.REF_DATA_CODE_PK
  AND
  RDF.EFFECTIVE_TO_DATE IS NULL
  AND
  RDCD.LANGUAGE_CODE = 'ENG'
),
FACILITY_BUS AS (
  SELECT
  FACILITY.ASSET_PK,
  RDCDT.SHORT_DESCRIPTION FACILITY_TYPE,
  RDCDBA.SHORT_DESCRIPTION BUSINESS_ACTIVITY

  FROM
  TARGET_FACILITY_ASSET TFA,
  AHBRP.FACILITY,
  AHBRP.FACILITY_BUSINESS_ACTIVTY FBA,
  AHBRP.FACILITY_TYPE FT,
  AHBRP.REF_DATA_SET RDST,
  AHBRP.REF_DATA_CODE RDCT,
  AHBRP.REF_DATA_CODE_DESC RDCDT,
  AHBRP.REF_DATA_SET RDSBA,
  AHBRP.REF_DATA_CODE RDCBA,
  AHBRP.REF_DATA_CODE_DESC RDCDBA

  WHERE
  TFA.ASSET_PK = FACILITY.ASSET_PK
  AND
  FACILITY.FACILITY_BUSINESS_ACTIVTY_PK = FBA.FACILITY_BUSINESS_ACTIVTY_PK
  AND
  FBA.FACILITY_TYPE_PK = FT.FACILITY_TYPE_PK
  AND
  RDST.REF_DATA_SET_NAME = 'FACILITY_TYPE'
  AND
  RDST.EFFECTIVE_TO_DATE IS NULL
  AND
  FT.FACILITY_TYPE_CODE = RDCT.CODE
  AND
  RDCT.EFFECTIVE_TO_DATE = '31-DEC-9999'
  AND
  RDST.REF_DATA_SET_PK = RDCT.REF_DATA_SET_PK
  AND
  RDCT.REF_DATA_CODE_PK = RDCDT.REF_DATA_CODE_PK
  AND
  RDCDT.LANGUAGE_CODE = 'ENG'
  AND
  RDSBA.REF_DATA_SET_NAME = 'FACILITY_BUSINESS_ACTIVITY'
  AND
  RDSBA.EFFECTIVE_TO_DATE IS NULL
  AND
  FBA.FACILITY_BUSINSS_ACTVTY_CODE = RDCBA.CODE
  AND
  RDCBA.EFFECTIVE_TO_DATE = '31-DEC-9999'
  AND
  RDSBA.REF_DATA_SET_PK = RDCBA.REF_DATA_SET_PK
  AND
  RDCBA.REF_DATA_CODE_PK = RDCDBA.REF_DATA_CODE_PK
  AND
  RDCDBA.LANGUAGE_CODE = 'ENG'
)

SELECT
LOCATION.LOCATION_ID,
LOCATION.FEATURE_NAME feature_name,
PAON_START_NUMBER paon_start_number,
PAON_START_NUMBER_SUFFIX paon_start_number_suffix,
PAON_END_NUMBER paon_end_number,
PAON_END_NUMBER_SUFFIX paon_end_number_suffix,
PAON_DESCRIPTION paon_description,
SAON_DESCRIPTION saon_description,
SAON_START_NUMBER saon_start_number,
SAON_START_NUMBER_SUFFIX saon_start_number_suffix,
SAON_END_NUMBER saon_end_number,
SAON_END_NUMBER_SUFFIX saon_end_number_suffix,
STREET,
LOCALITY,
TOWN,
ADMINISTRATIVE_AREA county,
POSTCODE,
UK_INTERNAL_CODE uk_internal_code,
COUNTRY_CODE country_code,
OS_MAP_REFERENCE os_map_reference,
CASE WHEN ASSET.ASSET_PK IS NULL THEN 'N/A' ELSE 'LU' END unit_type,
CASE WHEN UNIT_ID IS NULL THEN 'N/A' ELSE UNIT_ID END unit_id,
CASE WHEN LU_SPECIES.SHORT_DESCRIPTION IS NULL THEN 'N/A' ELSE LU_SPECIES.SHORT_DESCRIPTION END species,
CRAG.USUAL_QUANTITY_OF_ANIMALS usual_quantity_of_animals,
'N/A' facility_name,
'N/A' facility_type,
'N/A' business_activity,
FI.CPH cph

FROM
TARGET_LOCATION LOCATION,
AHBRP.FEATURE_ADDRESS FA,
AHBRP.FEATURE_STATE FS,
AHBRP.BS7666_ADDRESS BA,
TARGET_PRIMARY_ASSET_LOCATION AL,
AHBRP.LIVESTOCK_UNIT LU,
AHBRP.ASSET_STATE ASS,
AHBRP.FEATURE_POINT FP,
AHBRP.ASSET,
AHBRP.COLL_REGSTRD_ANIMAL_GROUP CRAG,
AHBRP.FEATURE_INVOLVEMENT FI,
LU_SPECIES

WHERE
LOCATION.FEATURE_PK = FA.FEATURE_PK(+)
AND
LOCATION.FEATURE_PK = FS.FEATURE_PK
AND
FA.ADDRESS_PK = BA.ADDRESS_PK(+)
AND
LOCATION.FEATURE_PK = AL.FEATURE_PK(+)
AND
AL.ASSET_PK = LU.ASSET_PK(+)
AND
LU.ASSET_PK = ASS.ASSET_PK(+)
AND
FA.FEATURE_ADDRESS_TO_DATE(+) IS NULL
AND
ASS.ASSET_STATUS_CODE(+) <> 'INACTIVE'
AND
ASS.ASSET_STATE_TO_DTTM(+) IS NULL
AND
FS.FEATURE_STATUS_CODE <> 'INACTIVE'
AND
FS.FEATURE_STATE_TO_DTTM IS NULL
AND
LOCATION.FEATURE_PK = FP.FEATURE_PK(+)
AND
PRIMARY_FEATURE_POINT_IND(+) = 'Y'
AND
FEATURE_POINT_TO_DATE(+) IS NULL
AND
LU.ASSET_PK = ASSET.ASSET_PK(+)
AND
ASSET.ANIMAL_PK = CRAG.ANIMAL_PK(+)
AND
ASSET.ASSET_PK = LU_SPECIES.ASSET_PK(+)
AND
LOCATION.FEATURE_PK = FI.FEATURE_PK(+)
AND
FI.FEATURE_INVOLVEMENT_TYPE(+) = 'CPHHOLDERSHIP'
AND
FI.FEATURE_INVOLV_TO_DATE(+) IS NULL

UNION ALL

SELECT
LOCATION.LOCATION_ID,
LOCATION.FEATURE_NAME feature_name,
PAON_START_NUMBER paon_start_number,
PAON_START_NUMBER_SUFFIX paon_start_number_suffix,
PAON_END_NUMBER paon_end_number,
PAON_END_NUMBER_SUFFIX paon_end_number_suffix,
PAON_DESCRIPTION paon_description,
SAON_DESCRIPTION saon_description,
SAON_START_NUMBER saon_start_number,
SAON_START_NUMBER_SUFFIX saon_start_number_suffix,
SAON_END_NUMBER saon_end_number,
SAON_END_NUMBER_SUFFIX saon_end_number_suffix,
STREET,
LOCALITY,
TOWN,
ADMINISTRATIVE_AREA county,
POSTCODE,
UK_INTERNAL_CODE uk_internal_code,
COUNTRY_CODE country_code,
OS_MAP_REFERENCE os_map_reference,
CASE WHEN ASSET.ASSET_PK IS NULL THEN 'N/A' ELSE 'F' END unit_type,
CASE WHEN UNIT_ID IS NULL THEN 'N/A' ELSE UNIT_ID END unit_id,
'N/A' species,
CRAG.USUAL_QUANTITY_OF_ANIMALS usual_quantity_of_animals,
CASE WHEN FACILITY_NAME IS NULL THEN 'N/A' ELSE FACILITY_NAME END facility_name,
CASE WHEN FACILITY_BUS.FACILITY_TYPE IS NULL THEN 'N/A' ELSE FACILITY_BUS.FACILITY_TYPE END facility_type,
CASE WHEN FACILITY_BUS.BUSINESS_ACTIVITY IS NULL THEN 'N/A' ELSE FACILITY_BUS.BUSINESS_ACTIVITY END business_activity,
FI.CPH cph

FROM
TARGET_LOCATION LOCATION,
AHBRP.FEATURE_ADDRESS FA,
AHBRP.FEATURE_STATE FS,
AHBRP.BS7666_ADDRESS BA,
TARGET_PRIMARY_ASSET_LOCATION AL,
AHBRP.FACILITY,
AHBRP.ASSET_STATE ASS,
AHBRP.FEATURE_POINT FP,
AHBRP.ASSET,
AHBRP.COLL_REGSTRD_ANIMAL_GROUP CRAG,
AHBRP.FEATURE_INVOLVEMENT FI,
FACILITY_BUS

WHERE
LOCATION.FEATURE_PK = FA.FEATURE_PK(+)
AND
LOCATION.FEATURE_PK = FS.FEATURE_PK
AND
FA.ADDRESS_PK = BA.ADDRESS_PK(+)
AND
LOCATION.FEATURE_PK = AL.FEATURE_PK(+)
AND
AL.ASSET_PK = FACILITY.ASSET_PK(+)
AND
FACILITY.ASSET_PK = ASS.ASSET_PK(+)
AND
ASS.ASSET_PK = FACILITY_BUS.ASSET_PK(+)
AND
FA.FEATURE_ADDRESS_TO_DATE(+) IS NULL
AND
ASS.ASSET_STATUS_CODE(+) <> 'INACTIVE'
AND
ASS.ASSET_STATE_TO_DTTM(+) IS NULL
AND
FS.FEATURE_STATUS_CODE <> 'INACTIVE'
AND
FS.FEATURE_STATE_TO_DTTM IS NULL
AND
LOCATION.FEATURE_PK = FP.FEATURE_PK(+)
AND
PRIMARY_FEATURE_POINT_IND(+) = 'Y'
AND
FEATURE_POINT_TO_DATE(+) IS NULL
AND
FACILITY.ASSET_PK = ASSET.ASSET_PK(+)
AND
ASSET.ANIMAL_PK = CRAG.ANIMAL_PK(+)
AND
LOCATION.FEATURE_PK = FI.FEATURE_PK(+)
AND
FI.FEATURE_INVOLVEMENT_TYPE(+) = 'CPHHOLDERSHIP'
AND
FI.FEATURE_INVOLV_TO_DATE(+) IS NULL
"
`;
